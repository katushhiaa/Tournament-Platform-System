# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tournament_db

# PgAdmin (Database Management)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# JWT (used by server to sign tokens). Change in production.
JWT__KEY=default-development-key-change-in-production
JWT__ISSUER=tournament-api
JWT__EXPIRATIONMINUTES=10
REFRESH_TOKEN_DAYS=14